{
  "name": "artana-frontdoor",
  "version": "0.1.0",
  "private": true,
  "description": "Public front door website for Artana.bio",
  "scripts": {
    "dev": "next dev -p ${PORT:-3010}",
    "dev:clean": "node -e \"const fs=require('fs');fs.rmSync('.next',{recursive:true,force:true});fs.rmSync('.next-dev',{recursive:true,force:true});\" && next dev -p ${PORT:-3010}",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib tests --ext .ts,.tsx --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "lucide-react": "^0.576.0",
    "motion": "^12.34.5",
    "next": "^15.5.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.12",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
